{
  "manifest_version": 3,
  "name": "Crovia Seal",
  "version": "0.8.0",
  "description": "Seal AI outputs with cryptographic Ed25519 receipts + invisible CIM watermarks that survive copy/paste. Verify sealed content anywhere on the web.",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_icon": "assets/icon-48.png",
    "default_title": "Crovia Seal",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://seal.croviatrust.com/*",
    "https://croviatrust.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/verify/verify.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
