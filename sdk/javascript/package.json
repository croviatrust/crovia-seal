{
  "name": "@crovia/seal",
  "version": "0.1.0",
  "description": "Immutable continuity receipts for evolving AI systems. Offline cryptographic primitive — Ed25519 + canonical JSON, no network required.",
  "license": "Apache-2.0",
  "author": "Crovia Trust <https://croviatrust.com>",
  "homepage": "https://croviatrust.com/seal",
  "repository": {
    "type": "git",
    "url": "https://github.com/croviatrust/crovia-seal.git",
    "directory": "sdk/javascript"
  },
  "bugs": {
    "url": "https://github.com/croviatrust/crovia-seal/issues"
  },
  "keywords": [
    "crovia",
    "seal",
    "continuity",
    "receipt",
    "ed25519",
    "provenance",
    "canonicalization",
    "ai",
    "transparency",
    "csc-1",
    "rfc-8785"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --minify --target=es2022",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "npm run build && du -sh dist/*",
    "prepublishOnly": "npm run test && npm run build"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
